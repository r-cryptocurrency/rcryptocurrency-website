# Next.js Web App Environment Variables
# Copy this file to .env in this directory (apps/web/.env)
# These are read at BUILD TIME by Next.js

# --- Newsletter & Admin ---
ADMIN_PASSWORD=your_secure_password_here
RESEND_API_KEY=re_...
RESEND_SEGMENT_ID=your_segment_id_here
RESEND_FROM_EMAIL=updates@updates.rcryptocurrency.com

# --- Database ---
# Usually inherited from root .env, but can be overridden here
# DATABASE_URL=postgresql://user:pass@localhost:5432/db
